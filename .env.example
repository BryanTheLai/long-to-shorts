# Copy to ".env" in the project root (or export in your shell). See docs/ENVIRONMENT.md.

# --- Stage LLM provider (stages 2 / 2.25 / 2.5 / 3) ---
# HUMEO_LLM_PROVIDER=gemini
# HUMEO_LLM_MODEL=gemini-3-flash-preview
# HUMEO_LLM_VISION_MODEL=

# --- Gemini (legacy envs still supported) ---
# Prefer GOOGLE_API_KEY (Google AI Studio / AI Studio API key).
GOOGLE_API_KEY=
# Legacy alias — only used if GOOGLE_API_KEY is unset:
# GEMINI_API_KEY=

# Model id for clip selection (legacy alias; generic override is HUMEO_LLM_MODEL)
#GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_MODEL=gemini-3-flash-preview

# --- OpenAI / Azure OpenAI for stages 2 / 2.25 / 2.5 / 3 ---
# OPENAI_BASE_URL=

# Endpoint-style Azure resources need an API version. Base-URL mode does not.
# We accept either name:
# AZURE_OPENAI_API_VERSION=2025-03-01-preview
# OPENAI_API_VERSION=2025-03-01-preview

# If both are set, AZURE_BASE_URL wins.
# AZURE_OPENAI_ENDPOINT=https://example-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=""

AZURE_ENDPOINT=https://lema-mb11yuk1-eastus2.services.ai.azure.com/api/projects/lead-gen-dev-eastus2

# AZURE_OPENAI_BASE_URL=https://example.services.ai.azure.com/openai/v1/
AZURE_BASE_URL=https://lema-mb11yuk1-eastus2.services.ai.azure.com/openai/v1/

# Optional deployment name when you use the endpoint-style Azure resource path:
# AZURE_OPENAI_DEPLOYMENT=gpt-5.4



# Optional: directory with clip_selection_system.jinja2 and clip_selection_user.jinja2
# HUMEO_PROMPTS_DIR=

# --- OpenAI (Whisper API) ---
OPENAI_API_KEY=sk-...
# Force OpenAI Whisper even if WhisperX is installed (e.g. Windows): openai | whisperx | auto
HUMEO_TRANSCRIBE_PROVIDER=openai

# --- Video cache (optional) ---
# Override default: ~/.cache/humeo (Unix) or %LOCALAPPDATA%/humeo (Windows)
# HUMEO_CACHE_ROOT=
